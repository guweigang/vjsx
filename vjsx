#!/bin/sh
set -eu

repo_root=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
vexe=${VEXE:-}

if [ -z "$vexe" ]; then
	vexe=$(command -v v || true)
fi

if [ -z "$vexe" ]; then
	echo "V compiler not found. Set VEXE or add v to PATH." >&2
	exit 1
fi

if [ -n "${VJS_V_FLAGS:-}" ]; then
	# shellcheck disable=SC2086
	exec "$vexe" $VJS_V_FLAGS run "$repo_root/vjsx_cli.vsh" "$@"
fi

exec "$vexe" run "$repo_root/vjsx_cli.vsh" "$@"
